# Asset Tracking System - Environment Variables


# Database credentials for services
DB_HOST=postgres
DB_PORT=5432
DB_USER=asset_tracking_db_user
DB_PASSWORD=rootpassword
DB_NAME=asset_tracking_db



# PGADMIN
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050


# Eureka Server Configuration

EUREKA_PORT=8761
EUREKA_CLIENT_REGISTER_WITH_EUREKA=false
EUREKA_CLIENT_FETCH_REGISTRY=false
EUREKA_SERVER_URL=http://eureka-server:8761/eureka/



# CONFIG SERVER

CONFIG_PORT=8888
CONFIG_URL=http://config-server:8888


# API Gateway Configuration

API_GATEWAY_PORT=8080

# Routes configuration
AUTH_SERVICE_URL=http://auth-service:8081
ASSET_SERVICE_URL=http://asset-service:8082
USER_SERVICE_URL=http://user-service:8083
REPORT_SERVICE_URL=http://report-service:8084
MAINTENANCE_SERVICE_URL=http://maintenance-service:8085

# == Microservices Ports ==

AUTH_SERVICE_PORT=8081
ASSET_SERVICE_PORT=8082
USER_SERVICE_PORT=8083
REPORT_SERVICE_PORT=8084
MAINTENANCE_SERVICE_PORT=8085


# JWT Configuration

JWT_SECRET=your-256-bit-secret-key-here-change-this-in-production
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000



# Spring Profiles

SPRING_PROFILES_ACTIVE=docker

