      "name": "Create asset",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/assets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "assets"
          ]
