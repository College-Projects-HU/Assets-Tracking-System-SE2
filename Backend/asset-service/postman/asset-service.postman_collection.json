        "description": "",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assetTag\": \"LAP-100\",\n  \"name\": \"MacBook Pro 14\",\n  \"category\": \"Laptop\",\n  \"serialNumber\": \"MBP14X1\",\n  \"purchaseCost\": 2399.0,\n  \"location\": \"HQ\"\n}"
        }
